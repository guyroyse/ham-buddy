# OpenAI
OPENAI_API_KEY=

# Redis Agent Memory (private preview)
MEMORY_API_HOST=
MEMORY_API_KEY=
MEMORY_STORE_ID=

# Yaesu FT-991 serial port (run `npm run rig:devices` to list).
RIG_PORT=/dev/cu.usbserial-01600C6F0
RIG_BAUD=38400
# Hamlib rig model — 1035 = FT-991A, 1029 = FT-991. See `rigctl --list`.
RIG_MODEL=1035

# Audio capture device — avfoundation index or name (run `npm run audio:devices`).
# Defaults to "0" (first device) if unset.
AUDIO_DEVICE=USB Audio CODEC
AUDIO_OUTPUT_DIR=./captures

# Free-form context about the operator's location, fed to the text corrector to
# help it fix misheard local proper nouns (towns, repeaters, clubs). Optional.
LOCATION_CONTEXT="Operator is in Newington, Connecticut (Hartford County, grid FN31pr). Nearby places: Hartford, New Britain, West Hartford, Berlin, Wethersfield. Local clubs: ARRL HQ (W1AW), Newington ARL. Common 2m repeaters: 146.94, 147.18, 145.45."

# Identifies the user in chatbot session memory — sets the session owner and the
# actorId on user turns. Use your callsign for callsign-scoped recall later.
USER_NAME=operator
